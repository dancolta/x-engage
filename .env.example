# Copy this file to .env and fill in your own values. Never commit .env.

# --- Notion (required) ---
# Notion integration token (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID where drafts get mirrored as a log
# (create a DB matching the schema in README.md, then share it with your integration)
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Claude CLI (required for drafting) ---
# Path to the claude CLI binary, if not on PATH
# CLAUDE_CLI=/usr/local/bin/claude

# --- X / Twitter API via xurl (required for fetching candidates) ---
# Install xurl globally: npm install -g xurl
# Then: xurl auth oauth2 login
# This skill calls `xurl whoami` to verify auth before fetching.

# --- Playwright (required for publishing) ---
# Persistent Chromium profile dir for the logged-in X session.
# After setup, you log into X once in this profile and the skill reuses it.
X_PROFILE_DIR=~/.x-comment/chrome-profile

# --- Kill switch ---
# Set to 1 to halt all posting immediately (overrides all other config)
X_COMMENT_HALT=0

# --- Optional: target audience timezone (for daily cap reset + posting windows) ---
TZ=UTC
